Cell[BoxData[
 RowBox[{
  RowBox[{"SGProduct", "[", 
   RowBox[{"No_", ",", "g1_List", ",", "g2_List"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "ToMatrix", ",", "Gens", ",", "\[IndentingNewLine]", "PGGens", ",", 
      "OhMat3x3Table", ",", "ProductMat", ",", "PGInd", ",", "InversePGGens", 
      ",", "\[IndentingNewLine]", "TransGens", ",", "TransMat", ",", 
      "TransInd"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"Set", " ", "up", " ", "generators"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Gens", "=", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"StringJoin", "[", 
        RowBox[{"\"\<SG\>\"", ",", 
         RowBox[{"ToString", "[", "No", "]"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ToMatrix", "[", 
       RowBox[{"IGens_", ",", "g_List"}], "]"}], ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"mat", ",", "i"}], "}"}], ",", 
        RowBox[{
         RowBox[{"mat", "=", " ", 
          RowBox[{"IdentityMatrix", "[", 
           RowBox[{"Length", "[", 
            RowBox[{"IGens", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], ";", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"i", "=", "1"}], ",", 
           RowBox[{"i", "<=", 
            RowBox[{"Length", "[", "IGens", "]"}]}], ",", 
           RowBox[{"i", "++"}], ",", 
           RowBox[{"mat", " ", "=", " ", 
            RowBox[{"mat", ".", 
             RowBox[{"MatrixPower", "[", 
              RowBox[{
               RowBox[{"IGens", "[", 
                RowBox[{"[", "i", "]"}], "]"}], ",", 
               RowBox[{"g", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}]}]}], "]"}], ";", 
         "mat"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"PGGens", "=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"PGList", ",", "i"}], "}"}], ",", 
        RowBox[{
         RowBox[{"PGList", "=", 
          RowBox[{"{", "}"}]}], ";", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"i", "=", "1"}], ",", 
           RowBox[{"i", "<=", 
            RowBox[{
             RowBox[{"Length", "[", "Gens", "]"}], "-", "3"}]}], ",", 
           RowBox[{"i", "++"}], ",", " ", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"PGList", ",", 
             RowBox[{
              RowBox[{"Gens", "[", 
               RowBox[{"[", 
                RowBox[{"i", "+", "3"}], "]"}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{";;", "3"}], ",", 
                RowBox[{";;", "3"}]}], "]"}], "]"}]}], "]"}]}], "]"}], ";", 
         " ", "PGList"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"InversePGGens", "=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"IGList", ",", "i"}], "}"}], ",", 
        RowBox[{
         RowBox[{"IGList", "=", 
          RowBox[{"{", "}"}]}], ";", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"i", "=", "1"}], ",", 
           RowBox[{"i", "<=", 
            RowBox[{
             RowBox[{"Length", "[", "Gens", "]"}], "-", "3"}]}], ",", 
           RowBox[{"i", "++"}], ",", " ", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"IGList", ",", 
             RowBox[{"Inverse", "[", 
              RowBox[{"Gens", "[", 
               RowBox[{"[", 
                RowBox[{"i", "+", "3"}], "]"}], "]"}], "]"}]}], "]"}]}], 
          "]"}], ";", " ", "IGList"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"TransGens", " ", "=", " ", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Gens", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"1", ";;", "3"}], ",", "4"}], "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"Gens", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"1", ";;", "3"}], ",", "4"}], "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"Gens", "[", 
           RowBox[{"[", "3", "]"}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"1", ";;", "3"}], ",", "4"}], "]"}], "]"}]}], "}"}], 
       "]"}]}], ";", "\[IndentingNewLine]", " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Find", " ", "PGInd", " ", "by", " ", "exhaustive", " ", "Search"}], 
       ",", " ", 
       RowBox[{
       "find", " ", "TransInd", " ", "by", " ", "Solving", " ", "a", " ", 
        "linear", " ", "equation"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"OhMat3x3Table", "=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"TotalNum", ",", "mat", ",", "TotalList", ",", "i"}], "}"}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"TotalNum", "=", 
          RowBox[{"2", "^", 
           RowBox[{"Length", "[", "PGGens", "]"}]}]}], ";", 
         RowBox[{"(*", 
          RowBox[{
          "For", " ", "now", " ", "we", " ", "do", " ", "not", " ", 
           "consider", " ", "other", " ", "possibilities"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"TotalList", " ", "=", " ", 
          RowBox[{"{", "}"}]}], ";", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"i", "=", "0"}], ",", 
           RowBox[{"i", "<", "TotalNum"}], ",", 
           RowBox[{"i", "++"}], ",", 
           RowBox[{
            RowBox[{"mat", " ", "=", " ", 
             RowBox[{"ToMatrix", "[", 
              RowBox[{"PGGens", ",", 
               RowBox[{"PadLeft", "[", 
                RowBox[{
                 RowBox[{"IntegerDigits", "[", 
                  RowBox[{"i", ",", "2"}], "]"}], ",", 
                 RowBox[{"Length", "[", "PGGens", "]"}]}], "]"}]}], "]"}]}], 
            ";", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"TotalList", ",", "mat"}], "]"}], ";"}]}], "]"}], ";", 
         "TotalList"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ProductMat", " ", "=", " ", 
      RowBox[{
       RowBox[{"ToMatrix", "[", 
        RowBox[{"Gens", ",", "g1"}], "]"}], ".", 
       RowBox[{"ToMatrix", "[", 
        RowBox[{"Gens", ",", "g2"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"PGInd", "=", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"PadLeft", "[", 
        RowBox[{
         RowBox[{"Characters", "[", 
          RowBox[{"IntegerString", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"(", 
              RowBox[{"(", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Position", "[", 
                   RowBox[{"OhMat3x3Table", ",", 
                    RowBox[{"ProductMat", "[", 
                    RowBox[{"[", 
                    RowBox[{
                    RowBox[{";;", "3"}], ",", 
                    RowBox[{";;", "3"}]}], "]"}], "]"}]}], "]"}], "[", 
                  RowBox[{"[", 
                   RowBox[{"1", ",", "1"}], "]"}], "]"}], "-", "1"}], ")"}], 
               ")"}], ")"}], ")"}], ",", "2"}], "]"}], "]"}], ",", 
         RowBox[{"Length", "[", "PGGens", "]"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"TransMat", "=", 
      RowBox[{"ProductMat", ".", 
       RowBox[{"ToMatrix", "[", 
        RowBox[{
         RowBox[{"Reverse", "[", "InversePGGens", "]"}], ",", 
         RowBox[{"Reverse", "[", "PGInd", "]"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"TransInd", "=", 
      RowBox[{"LinearSolve", "[", 
       RowBox[{"TransGens", ",", 
        RowBox[{"TransMat", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"1", ";;", "3"}], ",", "4"}], "]"}], "]"}]}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Join", "[", 
      RowBox[{"TransInd", ",", "PGInd"}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
