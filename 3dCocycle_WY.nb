               RowBox[{"Inverse", "[", 
                RowBox[{"Gens", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", "+", "3"}], "]"}], "]"}], "]"}]}], "]"}]}], 
            "]"}], ";", " ", "IGList"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", " ", 
       RowBox[{"(*", 
