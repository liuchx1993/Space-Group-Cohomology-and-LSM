Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"WeightedIntegerPartition", "[", 
    RowBox[{"degrees_", ",", "target_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"l", ",", "list", ",", "listPrime", ",", "i", ",", "j"}], "}"}],
      ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"l", "=", 
       RowBox[{"Length", "[", "degrees", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"l", "==", "1"}], ",", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{"target", ",", 
              RowBox[{"degrees", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "==", "0"}], ",", " ", 
           RowBox[{
            RowBox[{"Return", "[", 
             RowBox[{"{", 
              RowBox[{"{", 
               RowBox[{"Divide", "[", 
                RowBox[{"target", ",", 
                 RowBox[{"degrees", "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "}"}], "}"}], 
             "]"}], ";"}], ",", 
           RowBox[{"Return", "[", 
            RowBox[{"{", "}"}], "]"}]}], "]"}], ";"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"list", "=", 
          RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"i", "=", "0"}], ",", 
           RowBox[{
            RowBox[{"target", "-", 
             RowBox[{
              RowBox[{"degrees", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "*", "i"}]}], ">=", "0"}], ",", 
           RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"listPrime", "=", 
             RowBox[{"WeightedIntegerPartition", "[", 
              RowBox[{
               RowBox[{"Drop", "[", 
                RowBox[{"degrees", ",", "1"}], "]"}], ",", 
               RowBox[{"target", "-", 
                RowBox[{
                 RowBox[{"degrees", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "*", "i"}]}]}], "]"}]}], 
            ";", "\[IndentingNewLine]", 
            RowBox[{"For", "[", 
             RowBox[{
              RowBox[{"j", "=", "1"}], ",", 
              RowBox[{"j", "<=", 
               RowBox[{"Length", "[", "listPrime", "]"}]}], ",", 
              RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
              RowBox[{"list", " ", "=", " ", 
               RowBox[{"Append", "[", 
                RowBox[{"list", ",", " ", 
                 RowBox[{"Prepend", "[", 
                  RowBox[{
                   RowBox[{"listPrime", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], ",", "i"}], "]"}]}], 
                "]"}]}]}], "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "list", "]"}], ";"}]}], "\[IndentingNewLine]", 
    "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PrintSymbol", "[", 
   RowBox[{"symbols_", ",", "exponents_"}], "]"}], ":=", 
