Cell[BoxData[
 RowBox[{
  RowBox[{"GetAllElements", "[", 
   RowBox[{
   "symbols_", ",", " ", "degrees_", ",", " ", "relations_", ",", " ", 
    "target_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
     "BasisSetAll", ",", " ", "BasisSet", ",", " ", "basisNumber", ",", " ", 
      "relationsCode", ",", " ", "additionalSet", ",", "exponentj", ",", " ", 
      "ListPrime", ",", " ", "\[IndentingNewLine]", "m", ",", " ", "i", ",", 
      " ", "j", ",", " ", "k", ",", "d", ",", " ", "p", ",", 
      "\[IndentingNewLine]", "TrueBasis"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"BasisSetAll", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ",", 
       RowBox[{"i", "<=", "target"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"BasisSetAll", "=", 
         RowBox[{"Append", "[", 
          RowBox[{"BasisSetAll", ",", 
           RowBox[{"WeightedIntegerPartition", "[", 
            RowBox[{"degrees", ",", "i"}], "]"}]}], "]"}]}], ";"}]}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"BasisSet", "=", 
      RowBox[{"BasisSetAll", "[", 
       RowBox[{"[", 
        RowBox[{"target", "+", "1"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"basisNumber", " ", "=", " ", 
      RowBox[{"Length", "[", "BasisSet", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "BasisSet", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"relationsCode", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "<=", 
        RowBox[{"Length", "[", "relations", "]"}]}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"m", "=", 
         RowBox[{"MonomialList", "[", 
          RowBox[{"relations", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"d", "=", 
         RowBox[{"Dot", "[", 
          RowBox[{
           RowBox[{"Exponent", "[", 
            RowBox[{
             RowBox[{"m", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", "symbols"}], "]"}], ",", 
           "degrees"}], "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"target", ">=", "d"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"additionalSet", "=", 
            RowBox[{"BasisSetAll", "[", 
             RowBox[{"[", 
              RowBox[{"target", "-", "d", "+", "1"}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"For", "[", 
            RowBox[{
             RowBox[{"j", "=", "1"}], ",", 
             RowBox[{"j", "<=", 
              RowBox[{"Length", "[", "additionalSet", "]"}]}], ",", 
             RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"ListPrime", "=", 
               RowBox[{"ConstantArray", "[", 
                RowBox[{"0", ",", "basisNumber"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"For", "[", 
               RowBox[{
                RowBox[{"k", "=", "1"}], ",", 
                RowBox[{"k", "<=", 
                 RowBox[{"Length", "[", "m", "]"}]}], ",", 
                RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"exponentj", "=", 
                  RowBox[{
                   RowBox[{"Exponent", "[", 
                    RowBox[{
                    RowBox[{"m", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], ",", "symbols"}], "]"}], 
                   "+", 
                   RowBox[{"additionalSet", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"p", "=", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"Position", "[", 
                    RowBox[{"BasisSet", ",", "exponentj"}], "]"}], "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "[", 
                   RowBox[{"[", "1", "]"}], "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"ListPrime", "[", 
                   RowBox[{"[", "p", "]"}], "]"}], "=", "1"}], ";"}]}], "]"}],
               ";", "\[IndentingNewLine]", 
              RowBox[{"relationsCode", "=", 
               RowBox[{"Append", "[", 
                RowBox[{"relationsCode", ",", "ListPrime"}], "]"}]}], ";"}]}],
             "]"}]}]}], "]"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"r", "=", 
      RowBox[{"MatrixRank", "[", 
       RowBox[{"relationsCode", ",", 
        RowBox[{"Modulus", "->", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"TrueBasis", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "<=", "basisNumber"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"TestArray", "=", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0", ",", "basisNumber"}], "]"}]}], ";", 
        RowBox[{
         RowBox[{"TestArray", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "=", "1"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"relationsCode", "=", 
         RowBox[{"Append", "[", 
          RowBox[{"relationsCode", ",", "TestArray"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"MatrixRank", "[", "relationsCode", "]"}], "==", 
           RowBox[{"r", "+", "1"}]}], ",", 
          RowBox[{
           RowBox[{"r", "=", 
            RowBox[{"r", "+", "1"}]}], ";", 
           RowBox[{"TrueBasis", "=", 
            RowBox[{"Append", "[", 
             RowBox[{"TrueBasis", ",", "TestArray"}], "]"}]}], ";"}]}], "]"}],
         ";"}]}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "TrueBasis", "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
