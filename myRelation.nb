        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"target", ">=", "d"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"additionalSet", "=", 
            RowBox[{"BasisSetAll", "[", 
             RowBox[{"[", 
              RowBox[{"target", "-", "d", "+", "1"}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
           RowBox[{"For", "[", 
            RowBox[{
             RowBox[{"j", "=", "1"}], ",", 
