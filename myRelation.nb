Cell[BoxData[
 RowBox[{
  RowBox[{"PrintSymbol", "[", 
   RowBox[{"symbols_", ",", "exponents_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "i"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"x", "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "<=", 
        RowBox[{"Length", "[", "symbols", "]"}]}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"x", "=", 
         RowBox[{"x", "*", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"symbols", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "^", 
            RowBox[{"exponents", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "x", "]"}], ";"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9105979861859026`*^9, 3.9105981044251485`*^9}},
