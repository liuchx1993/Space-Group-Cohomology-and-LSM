        RowBox[{"BasisSetAll", "=", 
         RowBox[{"Append", "[", 
          RowBox[{"BasisSetAll", ",", 
           RowBox[{"WeightedIntegerPartition", "[", 
            RowBox[{"degrees", ",", "i"}], "]"}]}], "]"}]}], ";"}]}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"BasisSet", "=", 
