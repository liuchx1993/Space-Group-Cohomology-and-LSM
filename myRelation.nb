Cell[BoxData[
 RowBox[{
  RowBox[{"AddRows", "[", "mat_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"newMat", ",", "l1", ",", "l2", ",", "i"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"newMat", "=", "mat"}], ";", 
     RowBox[{"l2", "=", 
      RowBox[{"Length", "[", 
       RowBox[{"mat", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", 
     RowBox[{"l1", "=", 
      RowBox[{"l2", "-", 
       RowBox[{"Length", "[", "mat", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"l1", "<", "0"}], ",", 
       RowBox[{
        RowBox[{"Print", "[", "\"\<Error!\>\"", "]"}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "<=", "l1"}], ",", 
       RowBox[{"i", "++"}], ",", 
       RowBox[{"newMat", "=", 
        RowBox[{"Append", "[", 
         RowBox[{"newMat", ",", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", "l2"}], "]"}]}], "]"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "newMat", "]"}]}]}], "]"}]}]], "Input",
