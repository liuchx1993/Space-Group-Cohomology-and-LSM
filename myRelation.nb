    RowBox[{
     RowBox[{"BasisSetAll", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ",", 
       RowBox[{"i", "<=", "target"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
