Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ToMatrix", "[", 
    RowBox[{"IGens_", ",", " ", "g_List"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"mat", ",", "i"}], "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"mat", "=", 
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{"Length", "[", 
         RowBox[{"IGens", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], ";", " ", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<=", 
         RowBox[{"Length", "[", "IGens", "]"}]}], ",", 
        RowBox[{"i", "++"}], ",", " ", 
        RowBox[{"mat", "=", 
         RowBox[{"mat", ".", 
          RowBox[{"MatrixPower", "[", 
           RowBox[{
            RowBox[{"IGens", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{"g", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}]}]}], "]"}], ";", "\n", 
      RowBox[{"Return", "[", "mat", "]"}]}]}], "\n", "]"}]}], ";"}]], "Code",
