Cell[BoxData[
 RowBox[{
  RowBox[{"MakenonLSMTab", "[", 
   RowBox[{"No_", ",", " ", "CocycleTab_", ",", " ", "targetRank_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "PrepData", ",", " ", "TIList", ",", " ", "\n", "TestTab", ",", " ", 
      "TestTabN", ",", " ", "j", ",", " ", "k", ",", " ", "r", ",", " ", 
      "data"}], "}"}], ",", "\n", "\n", 
    RowBox[{
     RowBox[{"TIList", "=", 
      RowBox[{"FindnonLSMTI", "[", "No", "]"}]}], ";", "\n", "\n", 
     RowBox[{"TestTab", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "<=", 
        RowBox[{"Length", "[", "CocycleTab", "]"}]}], ",", " ", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"data", "=", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0", ",", " ", 
           RowBox[{"Length", "[", "TIList", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"k", "=", "1"}], ",", 
          RowBox[{"k", "<=", 
           RowBox[{"Length", "[", "TIList", "]"}]}], ",", 
          RowBox[{"k", "++"}], ",", " ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", 
              RowBox[{"TIList", "[", 
               RowBox[{"[", "k", "]"}], "]"}], "]"}], "==", "1"}], ",", " ", 
            RowBox[{
             RowBox[{"data", "[", 
              RowBox[{"[", "k", "]"}], "]"}], "=", 
             RowBox[{"TI1", "[", 
              RowBox[{
               RowBox[{"CocycleTab", "[", 
                RowBox[{"[", "j", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"TIList", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], "[", 
                RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ",", " ", 
            RowBox[{
             RowBox[{"data", "[", 
              RowBox[{"[", "k", "]"}], "]"}], "=", 
             RowBox[{"TI2", "[", 
              RowBox[{
               RowBox[{"CocycleTab", "[", 
                RowBox[{"[", "j", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"TIList", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"TIList", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}]}], "]"}]}], "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"TestTab", ",", "data"}], "]"}], ";"}]}], "]"}], ";", "\n", 
     "\n", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"MatrixRank", "[", 
         RowBox[{"TestTab", ",", 
          RowBox[{"Modulus", "->", "2"}]}], "]"}], "==", "targetRank"}], ",", 
       " ", 
       RowBox[{
       "Print", "[", "\"\<Successfull generate all non-LSM TIs\>\"", "]"}], 
       ",", " ", 
       RowBox[{
        RowBox[{
        "Print", "[", "\"\<Error! Cannot generate all non-LSM TIs\>\"", "]"}],
         ";", 
        RowBox[{"Return", "[", "TestTab", "]"}], ";"}]}], "]"}], ";", "\n", 
     "\n", 
     RowBox[{"TestTabN", "=", 
      RowBox[{"{", "}"}]}], ";", " ", 
     RowBox[{"r", "=", "0"}], ";", " ", 
     RowBox[{"TestTab", "=", 
      RowBox[{"Transpose", "[", "TestTab", "]"}]}], ";", "\n", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "<=", 
        RowBox[{"Length", "[", "TIList", "]"}]}], ",", 
       RowBox[{"j", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixRank", "[", 
           RowBox[{
            RowBox[{"Append", "[", 
             RowBox[{"TestTabN", ",", 
              RowBox[{"TestTab", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], "]"}], ",", 
            RowBox[{"Modulus", "->", "2"}]}], "]"}], "==", 
          RowBox[{"r", "+", "1"}]}], ",", " ", 
         RowBox[{
          RowBox[{"AppendTo", "[", 
           RowBox[{"TestTabN", ",", " ", 
            RowBox[{"TestTab", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}], "]"}], ";", 
          RowBox[{"r", "=", 
           RowBox[{"r", "+", "1"}]}], ";"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"TestTab", "=", 
      RowBox[{"Transpose", "[", "TestTabN", "]"}]}], ";", "\n", "\n", 
     "TestTab"}]}], "]"}]}]], "Code",
