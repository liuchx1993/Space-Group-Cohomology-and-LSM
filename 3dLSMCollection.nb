Cell[BoxData[
 RowBox[{
  RowBox[{"FindnonLSMTI", "[", "No_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "PrepData", ",", " ", "RotationList", ",", " ", "ReflectionList", ",", 
      " ", "CommutingReflectionList", ",", " ", "FourFoldRotationList", ",", 
      " ", "g", ",", " ", "k"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"PrepData", "=", 
      RowBox[{"Prep", "[", "No", "]"}]}], ";", "\n", 
     RowBox[{"RotationList", "=", 
      RowBox[{"FindRotation", "[", 
       RowBox[{"No", ",", "PrepData"}], "]"}]}], ";", "\n", 
     RowBox[{"ReflectionList", "=", 
      RowBox[{"FindReflection", "[", 
       RowBox[{"No", ",", "PrepData"}], "]"}]}], ";", "\n", "\n", 
     RowBox[{"CommutingReflectionList", "=", 
      RowBox[{"{", "}"}]}], ";", "\n", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"i", "==", "0"}], ")"}], "||", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"i", "!=", "0"}], "&&", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"m", "!=", "0"}], "||", 
              RowBox[{"c", "!=", "0"}], "||", 
              RowBox[{"cp", "!=", "0"}]}], ")"}]}], ")"}]}], ",", "\n", 
         RowBox[{
          RowBox[{"g", "=", 
           RowBox[{"{", 
            RowBox[{
            "x", ",", "y", ",", "z", ",", "c", ",", "cp", ",", "m", ",", 
             "i"}], "}"}]}], ";", "\n", 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"k", "=", "1"}], ",", 
            RowBox[{"k", "<=", 
             RowBox[{"Length", "[", "ReflectionList", "]"}]}], ",", 
            RowBox[{"k", "++"}], ",", "\n", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"SGProduct", "[", 
                RowBox[{"No", ",", "g", ",", 
                 RowBox[{
                  RowBox[{"ReflectionList", "[", 
                   RowBox[{"[", "k", "]"}], "]"}], "[", 
                  RowBox[{"[", "1", "]"}], "]"}], ",", "PrepData"}], "]"}], "==", 
               RowBox[{"SGProduct", "[", 
                RowBox[{"No", ",", 
                 RowBox[{
                  RowBox[{"ReflectionList", "[", 
                   RowBox[{"[", "k", "]"}], "]"}], "[", 
                  RowBox[{"[", "1", "]"}], "]"}], ",", "g", ",", "PrepData"}],
                 "]"}]}], ",", " ", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"CommutingReflectionList", ",", 
                RowBox[{"{", 
                 RowBox[{"g", ",", 
                  RowBox[{
                   RowBox[{"ReflectionList", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], "[", 
                   RowBox[{"[", "1", "]"}], "]"}]}], "}"}]}], "]"}]}], 
             "]"}]}], "]"}]}]}], "]"}], ",", "\n", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", 
         RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"cp", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"m", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "1"}], "}"}]}], "]"}], ";", "\n", "\n", 
     RowBox[{"FourFoldRotationList", "=", 
      RowBox[{"FindFourFoldRotation", "[", 
       RowBox[{"No", ",", " ", "PrepData"}], "]"}]}], ";", "\n", "\n", 
     RowBox[{"Join", "[", 
      RowBox[{
      "RotationList", ",", " ", "ReflectionList", ",", " ", 
       "CommutingReflectionList", ",", " ", "FourFoldRotationList"}], 
