Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Prep", "[", "No_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"No", "==", "1"}], ",", 
     RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "Gens", ",", "\[IndentingNewLine]", "PGGens", ",", "OhMat3x3Table", 
         ",", "InversePGGens", ",", "\[IndentingNewLine]", "TransGens", ",", 
         "InverseTransGens", ",", "\[IndentingNewLine]", "f", ",", "x", ",", 
         "y", ",", "z"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Gens", "=", 
         RowBox[{"ToExpression", "[", 
          RowBox[{"StringJoin", "[", 
           RowBox[{"\"\<SG\>\"", ",", 
            RowBox[{"ToString", "[", "No", "]"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"PGGens", "=", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"PGList", ",", "i"}], "}"}], ",", 
           RowBox[{
            RowBox[{"PGList", "=", 
             RowBox[{"{", "}"}]}], ";", 
            RowBox[{"For", "[", 
             RowBox[{
              RowBox[{"i", "=", "1"}], ",", 
              RowBox[{"i", "<=", 
               RowBox[{
                RowBox[{"Length", "[", "Gens", "]"}], "-", "3"}]}], ",", 
              RowBox[{"i", "++"}], ",", " ", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"PGList", ",", 
                RowBox[{
                 RowBox[{"Gens", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", "+", "3"}], "]"}], "]"}], "[", 
                 RowBox[{"[", 
                  RowBox[{
                   RowBox[{";;", "3"}], ",", 
                   RowBox[{";;", "3"}]}], "]"}], "]"}]}], "]"}]}], "]"}], ";",
             " ", "PGList"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"InversePGGens", "=", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"IGList", ",", "i"}], "}"}], ",", 
           RowBox[{
            RowBox[{"IGList", "=", 
             RowBox[{"{", "}"}]}], ";", 
            RowBox[{"For", "[", 
             RowBox[{
              RowBox[{"i", "=", "1"}], ",", 
              RowBox[{"i", "<=", 
               RowBox[{
                RowBox[{"Length", "[", "Gens", "]"}], "-", "3"}]}], ",", 
              RowBox[{"i", "++"}], ",", " ", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"IGList", ",", 
                RowBox[{"Inverse", "[", 
                 RowBox[{"Gens", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", "+", "3"}], "]"}], "]"}], "]"}]}], "]"}]}], 
             "]"}], ";", " ", "IGList"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", " ", 
        RowBox[{"(*", 
         RowBox[{
         "Find", " ", "PGInd", " ", "by", " ", "exhaustive", " ", "Search"}], 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"OhMat3x3Table", "=", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"TotalNum", ",", "mat", ",", "TotalList", ",", "i"}], 
            "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"TotalNum", "=", 
             RowBox[{"2", "^", 
              RowBox[{"Length", "[", "PGGens", "]"}]}]}], ";", 
            RowBox[{"(*", 
             RowBox[{
             "For", " ", "now", " ", "we", " ", "do", " ", "not", " ", 
              "consider", " ", "other", " ", "possibilities"}], "*)"}], 
            "\[IndentingNewLine]", 
            RowBox[{"TotalList", " ", "=", " ", 
             RowBox[{"{", "}"}]}], ";", 
            RowBox[{"For", "[", 
             RowBox[{
              RowBox[{"i", "=", "0"}], ",", 
              RowBox[{"i", "<", "TotalNum"}], ",", 
              RowBox[{"i", "++"}], ",", 
              RowBox[{
               RowBox[{"mat", " ", "=", " ", 
                RowBox[{"ToMatrix", "[", 
                 RowBox[{"PGGens", ",", 
                  RowBox[{"PadLeft", "[", 
                   RowBox[{
                    RowBox[{"IntegerDigits", "[", 
                    RowBox[{"i", ",", "2"}], "]"}], ",", 
                    RowBox[{"Length", "[", "PGGens", "]"}]}], "]"}]}], 
                 "]"}]}], ";", 
               RowBox[{"AppendTo", "[", 
                RowBox[{"TotalList", ",", "mat"}], "]"}], ";"}]}], "]"}], ";",
             "TotalList"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"TransGens", " ", "=", " ", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"Gens", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"1", ";;", "3"}], ",", "4"}], "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{"Gens", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"1", ";;", "3"}], ",", "4"}], "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{"Gens", "[", 
              RowBox[{"[", "3", "]"}], "]"}], "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"1", ";;", "3"}], ",", "4"}], "]"}], "]"}]}], "}"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"InverseTransGens", "=", 
         RowBox[{"Inverse", "[", "TransGens", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
         "Gens", ",", "PGGens", ",", "InversePGGens", ",", "OhMat3x3Table", 
          ",", "InverseTransGens"}], "}"}]}]}], "\[IndentingNewLine]", 
      "]"}]}], "]"}]}], ";"}]], "Code",
 CellLabel->"In[2]:=",ExpressionUUID->"bce0d606-86a2-4e3c-b4e0-e2d923d2da69"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SGProduct", "[", 
    RowBox[{"No_", ",", "g1_List", ",", "g2_List", ",", "PrepData_"}], "]"}], 
   ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"No", "==", "1"}], ",", 
     RowBox[{"g1", "+", "g2"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "Gens", ",", "PGGens", ",", "OhMat3x3Table", ",", "InversePGGens", 
         ",", "InverseTransGens", ",", "\[IndentingNewLine]", "ProductMat", 
         ",", "PGInd", ",", "TransInd", ",", "\[IndentingNewLine]", 
         "TransMat"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "Gens", ",", "PGGens", ",", "InversePGGens", ",", "OhMat3x3Table", 
           ",", "InverseTransGens"}], "}"}], "=", "PrepData"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ProductMat", " ", "=", " ", 
         RowBox[{
          RowBox[{"ToMatrix", "[", 
           RowBox[{"Gens", ",", "g1"}], "]"}], ".", 
          RowBox[{"ToMatrix", "[", 
           RowBox[{"Gens", ",", "g2"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"PGInd", "=", 
         RowBox[{"PadLeft", "[", 
          RowBox[{
           RowBox[{"IntegerDigits", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Position", "[", 
                RowBox[{"OhMat3x3Table", ",", 
                 RowBox[{"ProductMat", "[", 
                  RowBox[{"[", 
                   RowBox[{
                    RowBox[{";;", "3"}], ",", 
                    RowBox[{";;", "3"}]}], "]"}], "]"}]}], "]"}], "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "1"}], "]"}], "]"}], "-", "1"}], ",", "2"}],
             "]"}], ",", 
           RowBox[{"Length", "[", "PGGens", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"TransMat", "=", 
         RowBox[{"ProductMat", ".", 
          RowBox[{"ToMatrix", "[", 
           RowBox[{
            RowBox[{"Reverse", "[", "InversePGGens", "]"}], ",", 
            RowBox[{"Reverse", "[", "PGInd", "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"TransInd", "=", 
         RowBox[{"InverseTransGens", ".", 
          RowBox[{"TransMat", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"1", ";;", "3"}], ",", "4"}], "]"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Join", "[", 
         RowBox[{"TransInd", ",", "PGInd"}], "]"}]}]}], "\[IndentingNewLine]",
       "]"}]}], "]"}]}], ";"}]], "Code",
 CellLabel->"In[3]:=",ExpressionUUID->"94d4801b-057b-4877-a6a5-c5df833c50c0"],

