Cell[CellGroupData[{

Cell["Codes for checking element number", "Section",
 CellChangeTimes->{{3.9181041857173796`*^9, 3.918104224780299*^9}, 
   3.9181042793201237`*^9, {3.9181062582869205`*^9, 
   3.918106262652954*^9}},ExpressionUUID->"0d913c72-2355-4227-a3c8-\
8df1a2191a8a"],

Cell["\<\
Codes for checking the Z2 dimension in each degree

The main function is

GetAllElements[symbols_, degrees_, relations_, target_]

For a Z2 cohomology ring
\tsymbols, degrees: generators of the cohomology ring and their corresponding \
degrees 
\trelations: the relations of the cohomology ring (generators of a sub - ring \
that should be mod out)
\ttarget: the degree which we look at
  
  Output: a complete basis of the Z2 cohomology ring at the degree, written \
in terms of the symbols of the generators
  
  (*Caveat: The codes to get the basis may be inefficient*)\
\>", "Text",
 CellChangeTimes->{{3.91810429231357*^9, 
  3.9181045104447412`*^9}},ExpressionUUID->"e311e184-c1e7-4195-9629-\
b0b596a3898f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"WeightedIntegerPartition", "[", 
     RowBox[{"degrees_", ",", "target_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"l", ",", "list", ",", "listPrime", ",", "i", ",", "j"}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"l", "=", 
        RowBox[{"Length", "[", "degrees", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"l", "==", "1"}], ",", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{"target", ",", 
               RowBox[{"degrees", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "==", "0"}], ",", 
            " ", 
            RowBox[{
             RowBox[{"Return", "[", 
              RowBox[{"{", 
               RowBox[{"{", 
                RowBox[{"Divide", "[", 
                 RowBox[{"target", ",", 
                  RowBox[{"degrees", "[", 
                   RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "}"}], "}"}], 
              "]"}], ";"}], ",", 
            RowBox[{"Return", "[", 
             RowBox[{"{", "}"}], "]"}]}], "]"}], ";"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"list", "=", 
           RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"i", "=", "0"}], ",", 
            RowBox[{
             RowBox[{"target", "-", 
              RowBox[{
               RowBox[{"degrees", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "*", "i"}]}], ">=", "0"}], 
            ",", 
            RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"listPrime", "=", 
              RowBox[{"WeightedIntegerPartition", "[", 
               RowBox[{
                RowBox[{"Drop", "[", 
                 RowBox[{"degrees", ",", "1"}], "]"}], ",", 
                RowBox[{"target", "-", 
                 RowBox[{
                  RowBox[{"degrees", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "*", "i"}]}]}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"For", "[", 
              RowBox[{
               RowBox[{"j", "=", "1"}], ",", 
               RowBox[{"j", "<=", 
                RowBox[{"Length", "[", "listPrime", "]"}]}], ",", 
               RowBox[{"j", "++"}], ",", " ", 
               RowBox[{"AppendTo", "[", 
                RowBox[{"list", ",", " ", 
                 RowBox[{"Prepend", "[", 
                  RowBox[{
                   RowBox[{"listPrime", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], ",", "i"}], "]"}]}], 
                "]"}]}], "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}]}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Return", "[", "list", "]"}], ";"}]}], "\[IndentingNewLine]", 
     "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"PrintSymbol", "[", 
    RowBox[{"symbols_", ",", "exponents_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "i"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"x", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<=", 
         RowBox[{"Length", "[", "symbols", "]"}]}], ",", 
        RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"x", "=", 
          RowBox[{"x", "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"symbols", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "^", 
             RowBox[{"exponents", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}]}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "x", "]"}], ";"}]}], "]"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.910576339488612*^9, 3.910576404610284*^9}, {
   3.9105764346961203`*^9, 3.910576544012402*^9}, {3.910576591460642*^9, 
   3.9105767419896946`*^9}, 3.9105767826701217`*^9, {3.910576826427074*^9, 
   3.9105768937381644`*^9}, {3.910576926174543*^9, 3.910577006662424*^9}, {
   3.9105771078971033`*^9, 3.910577141900161*^9}, {3.910577220597395*^9, 
   3.9105772208505163`*^9}, {3.910577341565281*^9, 3.910577432807288*^9}, {
   3.910577557335473*^9, 3.9105777449305506`*^9}, {3.910577777700694*^9, 
   3.9105777886683674`*^9}, {3.910577899538362*^9, 3.9105779331584845`*^9}, {
   3.910577993111393*^9, 3.9105780290830746`*^9}, {3.910649118481477*^9, 
   3.91064911909319*^9}, {3.917512700188627*^9, 3.9175127074969916`*^9}, {
   3.9181059701518717`*^9, 3.9181059987987266`*^9}, 3.9181161545966835`*^9},
 CellLabel->"In[69]:=",ExpressionUUID->"9f92eb4c-2d95-4162-a867-4cea82f34d6a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"GetAllElements", "[", 
    RowBox[{
    "symbols_", ",", " ", "degrees_", ",", " ", "relations_", ",", " ", 
     "target_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
      "basisSetAll", ",", " ", "basisSet", ",", " ", "basisNumber", ",", " ", 
       "relationsCode", ",", " ", "additionalSet", ",", "exponentj", ",", " ",
        "listPrime", ",", " ", "testArray", ",", "tempMat", ",", 
       "\[IndentingNewLine]", "m", ",", "mRaw", ",", "x", ",", " ", "i", ",", 
       " ", "j", ",", " ", "k", ",", "d", ",", " ", "p", ",", "r", ",", 
       "\[IndentingNewLine]", "trueBasis"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"basisSetAll", "=", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "0"}], ",", 
        RowBox[{"i", "<=", "target"}], ",", 
        RowBox[{"i", "++"}], ",", " ", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{"basisSetAll", ",", 
           RowBox[{"WeightedIntegerPartition", "[", 
            RowBox[{"degrees", ",", "i"}], "]"}]}], "]"}], ";"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"basisSet", "=", 
       RowBox[{"basisSetAll", "[", 
        RowBox[{"[", 
         RowBox[{"target", "+", "1"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"basisNumber", "=", 
       RowBox[{"Length", "[", "basisSet", "]"}]}], ";", "\[IndentingNewLine]",
       "\[IndentingNewLine]", 
      RowBox[{"relationsCode", "=", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<=", 
         RowBox[{"Length", "[", "relations", "]"}]}], ",", 
        RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"mRaw", "=", 
          RowBox[{"MonomialList", "[", 
           RowBox[{"relations", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"d", "=", 
          RowBox[{"Dot", "[", 
           RowBox[{
            RowBox[{"Exponent", "[", 
             RowBox[{
              RowBox[{"mRaw", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", "symbols"}], "]"}], ",", 
            "degrees"}], "]"}]}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"m", "=", 
          RowBox[{"{", "}"}]}], ";", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"j", "=", "1"}], ",", 
           RowBox[{"j", "<=", 
            RowBox[{"Length", "[", "mRaw", "]"}]}], ",", 
           RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Dot", "[", 
                RowBox[{
                 RowBox[{"Exponent", "[", 
                  RowBox[{
                   RowBox[{"mRaw", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], ",", "symbols"}], "]"}], 
                 ",", "degrees"}], "]"}], "!=", "d"}], ",", " ", 
              RowBox[{
               RowBox[{"Print", "[", 
                RowBox[{
                "\"\<Error in degrees! Mismatch detected in \>\"", ",", "i", 
                 ",", "\"\< relation!\>\""}], "]"}], ";", 
               RowBox[{"Return", "[", 
                RowBox[{"{", "}"}], "]"}], ";"}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"x", "=", 
             RowBox[{"PrintSymbol", "[", 
              RowBox[{"symbols", ",", 
               RowBox[{"Exponent", "[", 
                RowBox[{
                 RowBox[{"mRaw", "[", 
                  RowBox[{"[", "j", "]"}], "]"}], ",", "symbols"}], "]"}]}], 
              "]"}]}], ";", " ", 
            RowBox[{"(*", "PolynomialMod2", "*)"}], 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Mod", "[", 
                RowBox[{
                 RowBox[{"Coefficient", "[", 
                  RowBox[{
                   RowBox[{"mRaw", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], ",", "x"}], "]"}], ",", 
                 "2"}], "]"}], "==", "1"}], ",", 
              RowBox[{
               RowBox[{"AppendTo", "[", 
                RowBox[{"m", ",", "x"}], "]"}], ";"}]}], "]"}], ";"}]}], 
          "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"target", ">=", "d"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"additionalSet", "=", 
             RowBox[{"basisSetAll", "[", 
              RowBox[{"[", 
               RowBox[{"target", "-", "d", "+", "1"}], "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"For", "[", 
             RowBox[{
              RowBox[{"j", "=", "1"}], ",", 
              RowBox[{"j", "<=", 
               RowBox[{"Length", "[", "additionalSet", "]"}]}], ",", 
              RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"listPrime", "=", 
                RowBox[{"ConstantArray", "[", 
                 RowBox[{"0", ",", "basisNumber"}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"For", "[", 
                RowBox[{
                 RowBox[{"k", "=", "1"}], ",", 
                 RowBox[{"k", "<=", 
                  RowBox[{"Length", "[", "m", "]"}]}], ",", 
                 RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"exponentj", "=", 
                   RowBox[{
                    RowBox[{"Exponent", "[", 
                    RowBox[{
                    RowBox[{"m", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], ",", "symbols"}], "]"}], 
                    "+", 
                    RowBox[{"additionalSet", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}]}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"p", "=", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"Position", "[", 
                    RowBox[{"basisSet", ",", "exponentj"}], "]"}], "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"listPrime", "[", 
                    RowBox[{"[", "p", "]"}], "]"}], "=", 
                   RowBox[{"1", "-", 
                    RowBox[{"listPrime", "[", 
                    RowBox[{"[", "p", "]"}], "]"}]}]}], ";"}]}], "]"}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"relationsCode", "=", 
                RowBox[{"Append", "[", 
                 RowBox[{"relationsCode", ",", "listPrime"}], "]"}]}], 
               ";"}]}], "]"}]}]}], "]"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "relationsCode", "]"}], "!=", "0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", "Inefficient", "*)"}], 
        RowBox[{
         RowBox[{"tempMat", "=", 
          RowBox[{"NullSpace", "[", 
           RowBox[{"relationsCode", ",", 
            RowBox[{"Modulus", "->", "2"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "tempMat", "]"}], "!=", "0"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"tempMat", "=", 
             RowBox[{"NullSpace", "[", 
              RowBox[{"tempMat", ",", 
               RowBox[{"Modulus", "->", "2"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"r", "=", 
             RowBox[{"MatrixRank", "[", 
              RowBox[{"tempMat", ",", 
               RowBox[{"Modulus", "->", "2"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"trueBasis", "=", 
             RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"For", "[", 
             RowBox[{
              RowBox[{"i", "=", "1"}], ",", 
              RowBox[{"i", "<=", "basisNumber"}], ",", 
              RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"testArray", "=", 
                RowBox[{"ConstantArray", "[", 
                 RowBox[{"0", ",", "basisNumber"}], "]"}]}], ";", " ", 
               RowBox[{
                RowBox[{"testArray", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "=", "1"}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"MatrixRank", "[", 
                   RowBox[{
                    RowBox[{"Append", "[", 
                    RowBox[{"tempMat", ",", "testArray"}], "]"}], ",", 
                    RowBox[{"Modulus", "->", "2"}]}], "]"}], "==", 
                  RowBox[{"r", "+", "1"}]}], ",", " ", 
                 RowBox[{
                  RowBox[{"AppendTo", "[", 
                   RowBox[{"tempMat", ",", "testArray"}], "]"}], ";", 
                  RowBox[{"r", "=", 
                   RowBox[{"r", "+", "1"}]}], ";", "\[IndentingNewLine]", 
                  RowBox[{"AppendTo", "[", 
                   RowBox[{"trueBasis", ",", 
                    RowBox[{"PrintSymbol", "[", 
                    RowBox[{"symbols", ",", 
                    RowBox[{"basisSet", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], "]"}], ";"}]}],
                 "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"Return", "[", "trueBasis", "]"}], ";"}], ",", " ", 
           RowBox[{"Return", "[", 
            RowBox[{"{", "}"}], "]"}]}], "]"}]}], ",", "\n", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"trueBasis", "=", 
          RowBox[{"{", "}"}]}], ";", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"i", "=", "1"}], ",", 
           RowBox[{"i", "<=", "basisNumber"}], ",", 
           RowBox[{"i", "++"}], ",", 
           RowBox[{
            RowBox[{"AppendTo", "[", 
             RowBox[{"trueBasis", ",", 
              RowBox[{"PrintSymbol", "[", 
               RowBox[{"symbols", ",", 
                RowBox[{"basisSet", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], "]"}], ";"}]}], 
          "]"}], ";", 
         RowBox[{"Return", "[", "trueBasis", "]"}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";"}]}], "]"}]}], ";"}]], "Code",
 CellChangeTimes->{{3.910575619974578*^9, 3.910575648116742*^9}, {
