             RowBox[{"i", "<=", 
              RowBox[{
               RowBox[{"Length", "[", "Gens", "]"}], "-", "3"}]}], ",", 
             RowBox[{"i", "++"}], ",", " ", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"PGList", ",", 
               RowBox[{
                RowBox[{"Gens", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", "+", "3"}], "]"}], "]"}], "[", 
